DATABASE_URL=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# --- AI chatbot ---
# Which LLM provider answers. One of: google (default) | anthropic | openai
AI_PROVIDER=google
# Optional: override the default model id for the chosen provider
# AI_MODEL=gemini-2.0-flash

# Provider API keys (only the one matching AI_PROVIDER is required)
GOOGLE_GENERATIVE_AI_API_KEY=YOUR_GEMINI_KEY_HERE
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE
# OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE

# --- RAG (Phase 2) ---
# Which embedding provider generates vectors. One of: google (default)
EMBEDDING_PROVIDER=google
# Embedding model id. Use gemini-embedding-001 (returns one vector PER input for batching);
# do NOT use gemini-embedding-2 here (it aggregates a list into a single vector).
EMBEDDING_MODEL=gemini-embedding-001
# Output vector dimensionality — MUST match the Atlas $vectorSearch index (Step 2).
EMBEDDING_DIMS=768
# Retrieval arm for the chatbot: db (queryProducts only) | rag (searchKnowledgeBase only) | both
# Default here; the /chat request body can override per call for A/B testing.
RETRIEVAL_MODE=db
